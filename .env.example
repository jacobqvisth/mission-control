# Mission Control - Production Environment Template
# Copy values into Vercel Project Settings -> Environment Variables

# App
MISSION_CONTROL_ENV=production
MISSION_CONTROL_BASE_URL=https://mission-control.vercel.app

# Security (generate long random values)
MC_API_KEY=replace-with-long-random-secret
MC_WEBHOOK_SECRET=replace-with-long-random-secret

# OpenClaw / Gateway Integration
OPENCLAW_GATEWAY_URL=https://your-gateway.example.com
OPENCLAW_GATEWAY_TOKEN=replace-with-gateway-token
OPENCLAW_ACCOUNT_ID=default

# Telegram Integration
TELEGRAM_BOT_TOKEN=replace-with-bot-token
TELEGRAM_CHAT_ID=-1003729726136

# Optional observability
LOG_LEVEL=info
SENTRY_DSN=
